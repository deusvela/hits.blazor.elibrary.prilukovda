@page "/readers/add"
@page "/readers/edit/{ReaderId:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IDataService DataService
@inject NavigationManager NavManager

<h3>@(IsEditMode ? "Редактировать читателя" : "Добавить читателя")</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<EditForm Model="@reader" OnValidSubmit="Save">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>ФИО:</label>
        <InputText class="form-control" @bind-Value="reader.FullName" />
        <ValidationMessage For="() => reader.FullName" />
    </div>

    <div class="mb-3">
        <label>Телефон:</label>
        <InputText class="form-control" @bind-Value="reader.PhoneNumber" />
        <ValidationMessage For="() => reader.PhoneNumber" />
    </div>

    <div class="mb-3">
        <label>Email:</label>
        <InputText class="form-control" @bind-Value="reader.Email" />
        <ValidationMessage For="() => reader.Email" />
    </div>

    <button type="submit" class="btn btn-primary">Сохранить</button>
    <button type="button" class="btn btn-secondary ms-2" @onclick='() => NavManager.NavigateTo("/readers")'>
        Отмена
    </button>
</EditForm>

@code {
    [Parameter]
    public int? ReaderId { get; set; }

    private Reader reader = new();
    private string errorMessage = string.Empty;

    private bool IsEditMode => ReaderId.HasValue;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            errorMessage = string.Empty;

            if (IsEditMode && ReaderId != null)
            {
                reader = await DataService.GetReaderByIdAsync(ReaderId.Value) ?? new Reader();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task Save()
    {
        try
        {
            errorMessage = string.Empty;
            await DataService.AddOrUpdateReaderAsync(reader);
            NavManager.NavigateTo("/readers");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}